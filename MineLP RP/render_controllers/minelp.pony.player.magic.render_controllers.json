{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.minelp.pony.player.magic": {
            "geometry": "Geometry.minelp_unicorn",
            "part_visibility": [
                { "*": false },
                { "hornGlow": "variable.minelp_horn_type > 0 && (variable.is_holding_left || variable.is_holding_right)" },
                { "leftItemMagic": "variable.minelp_horn_type > 0 && variable.is_holding_left" },
                { "rightItemMagic": "variable.minelp_horn_type > 0 && variable.is_holding_right" }
            ],
            "materials": [
                { "*": "Material.minelp_magic" }
            ],
            "textures": ["Texture.default"],
            "ignore_lighting": true
        }
    }
}