{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.minelp.pony.player.magic": {
            "geometry": "Geometry.minelp_default",
            "part_visibility": [
                { "*": false },
                { "hornGlow": "variable.minelp_horn_type > 0 && (!q.is_item_name_any('slot.weapon.offhand', 0, '') || !q.is_item_name_any('slot.weapon.mainhand', 0, ''))" },
                { "leftItemMagic": "variable.minelp_horn_type > 0 && !q.is_item_name_any('slot.weapon.offhand', 0, '')" },
                { "rightItemMagic": "variable.minelp_horn_type > 0 && !q.is_item_name_any('slot.weapon.mainhand', 0, '')" }
            ],
            "materials": [
                { "*": "Material.minelp_magic" }
            ],
            "textures": ["Texture.default"],
            "ignore_lighting": false
        }
    }
}